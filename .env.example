# API Server
HTTP_PORT=8080
NODE_SECRET=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-long-random-secret
MARIADB_DSN=bangmod:bangmod@tcp(localhost:3306)/bangmod?parseTime=true&charset=utf8mb4
CLICKHOUSE_DSN=clickhouse://default:@localhost:9000/bangmod

# Agent
AGENT_TOKEN=your-agent-token-here
API_URL=http://localhost:8080
AGENT_INTERVAL=30
AGENT_REGION=th

# Probe Node
NODE_SECRET=change-me-to-a-long-random-secret
PROBE_REGION=th
PROBE_INTERVAL=60
PROBE_TARGETS=https://your-site.com,https://your-api.com
PROBE_TCP_TARGETS=your-db.example.com:3306,your-site.com:443

# Stripe Billing (optional — set to enable paid plans)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_REGION_PRICE_ID=price_...
APP_BASE_URL=http://localhost:3000

# Alert Engine
EVAL_INTERVAL=60
# channel_config examples:
# Slack:    {"webhook_url":"https://hooks.slack.com/services/..."}
# Discord:  {"webhook_url":"https://discord.com/api/webhooks/..."}
# Telegram: {"bot_token":"123:ABC","chat_id":"-100123"}
# Email:    {"smtp_host":"smtp.gmail.com","smtp_port":"587","username":"x@y.com","password":"...","from":"x@y.com","to":"y@z.com"}
