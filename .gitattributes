# Normalize all text files to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Force LF for Go, JS/TS, config, shell scripts
*.go    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf

# Binaries — never touch
*.exe   binary
*.png   binary
*.jpg   binary
